---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortPosts } from "../lib/blog";

const posts = sortPosts(await getCollection("blog"));
---

<BaseLayout title="文章" description="Choooppy 的个人博客，记录技术学习、项目实践与生活思考。" active="home">
  <main class="wide-container home-articles" id="articles">
    <div class="main-column">
      <section class="home-feed" aria-labelledby="articles-title">
        <div class="section-heading"><div><h1 id="articles-title">文章</h1></div></div>
        <div class="article-search" role="search">
          <span class="search-icon" aria-hidden="true"></span>
          <label class="sr-only" for="article-search-input">搜索文章</label>
          <input id="article-search-input" type="search" placeholder="输入关键词" autocomplete="off" data-article-search />
          <button class="search-clear" type="button" aria-label="清空搜索" title="清空搜索" data-search-clear hidden>×</button>
        </div>
        <p class="search-result" aria-live="polite" data-search-result>全部 {posts.length} 篇文章</p>
        <div class="article-list" aria-label="文章列表" data-article-list>
          {posts.map((post) => <ArticleCard post={post} />)}
          <p class="content-status" data-search-empty hidden>没有找到相关文章。</p>
        </div>
      </section>
    </div>
  </main>
  <script>
  const searchInput = document.querySelector<HTMLInputElement>("[data-article-search]");

  if (searchInput) {
    const searchClear = document.querySelector<HTMLButtonElement>("[data-search-clear]");
    const searchResult = document.querySelector<HTMLElement>("[data-search-result]");
    const searchEmpty = document.querySelector<HTMLElement>("[data-search-empty]");
    const articleItems = [...document.querySelectorAll<HTMLElement>("[data-article-item]")];
    const normalize = (value: string) => value.normalize("NFKC").toLocaleLowerCase("zh-CN").trim();

    const filterArticles = (query = "") => {
      const terms = normalize(query).split(/\s+/).filter(Boolean);
      let visible = 0;

      articleItems.forEach((item) => {
        const searchText = item.dataset.searchText ?? "";
        const matches = terms.every((term) => searchText.includes(term));
        item.hidden = !matches;
        if (matches) visible += 1;
      });

      if (searchClear) searchClear.hidden = terms.length === 0;
      if (searchEmpty) {
        searchEmpty.hidden = visible !== 0;
        searchEmpty.textContent = `没有找到与“${query.trim()}”相关的文章。`;
      }
      if (searchResult) {
        searchResult.textContent = terms.length > 0
          ? `找到 ${visible} 篇相关文章`
          : `全部 ${articleItems.length} 篇文章`;
      }
    };

    const requestedTag = new URLSearchParams(location.search).get("tag") ?? "";
    searchInput.value = requestedTag;
    searchInput.addEventListener("input", () => filterArticles(searchInput.value));
    searchClear?.addEventListener("click", () => {
      searchInput.value = "";
      filterArticles();
      searchInput.focus();
    });
    filterArticles(requestedTag);
  }
  </script>
</BaseLayout>
